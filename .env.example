# gitchain-lite — alles optional; ohne diese Datei laeuft ein reiner Git-Server mit BM25-Suche.
# Kopieren nach .env und vor dem Start sourcen (oder Variablen direkt exportieren).

# Kern
PORT=7420
REPO_BASE_PATH=./repos

# Dense Suche (optional): OpenAI-kompatibler /v1/embeddings-Endpunkt, 768-d empfohlen.
# Nicht gesetzt -> Suche laeuft lexikalisch (BM25); gesetzt -> dense+BM25 fusioniert.
#EMBED_URL=http://127.0.0.1:11434/v1/embeddings

# Antworten (optional): OpenAI-kompatibler /v1/chat/completions-Endpunkt.
# Nicht gesetzt -> /api/v1/query liefert zitierte Treffer ohne Antworttext.
#CHAT_URL=http://127.0.0.1:11434/v1/chat/completions

# PDF-Ingest (optional): baut Container aus gepushten docs/-PDFs.
# Voraussetzung: pip3 install numpy pymupdf
#INGEST_CMD=node ./ingest-worker.mjs --ingest
#PYTHON_BIN=python3
#TOOLKIT_DIR=./toolkit

# Speicher: max. resident gehaltene Container (Vektoren + BM25-Index), Default 8
#VEC_CACHE_MAX=8
